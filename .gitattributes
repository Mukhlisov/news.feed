# =============================================================================
# .gitattributes - Line ending and file handling rules for the news.feed project
# =============================================================================

# ------------------------------------------------------------------
# Global normalization
# ------------------------------------------------------------------
# Auto-detect text files and normalize line endings to LF on commit
# and to the OS native format on checkout.
* text=auto

# ------------------------------------------------------------------
# Source code and project files - always LF (cross-platform friendly)
# ------------------------------------------------------------------
*.cs                text eol=lf
*.csproj            text eol=lf
*.props             text eol=lf
*.targets           text eol=lf
*.sln               text eol=lf
*.fsproj            text eol=lf
*.vbproj            text eol=lf
*.nuspec            text eol=lf

# ------------------------------------------------------------------
# Configuration and data files
# ------------------------------------------------------------------
*.json              text eol=lf
*.xml               text eol=lf
*.config            text eol=lf
*.yml               text eol=lf
*.yaml              text eol=lf
*.md                text eol=lf
*.txt               text eol=lf
*.editorconfig      text eol=lf
*.gitignore         text eol=lf
*.gitattributes     text eol=lf

# ------------------------------------------------------------------
# Scripts
# ------------------------------------------------------------------
*.sh                text eol=lf
*.ps1               text eol=crlf   # PowerShell scripts often work better with CRLF on Windows
*.psm1              text eol=crlf

# ------------------------------------------------------------------
# Binary files - never attempt line ending conversion or diffing as text
# ------------------------------------------------------------------
*.dll               binary
*.exe               binary
*.pdb               binary
*.nupkg             binary
*.snupkg            binary

# Images
*.png               binary
*.jpg               binary
*.jpeg              binary
*.gif               binary
*.ico               binary
*.webp              binary
*.bmp               binary
*.svg               text      # SVGs are XML-based, treat as text

# Fonts
*.ttf               binary
*.otf               binary
*.eot               binary
*.woff              binary
*.woff2             binary

# Archives and other binaries
*.zip               binary
*.7z                binary
*.tar               binary
*.gz                binary
*.rar               binary

# Certificates and keys
*.pfx               binary
*.p12               binary
*.cer               binary
*.crt               binary

# IDE / Tool specific
*.DotSettings       text eol=lf
*.user              text eol=lf
*.suo               binary

# ------------------------------------------------------------------
# Optional: Merge strategies to reduce conflicts (uncomment if needed)
# ------------------------------------------------------------------
# *.sln               merge=union
# *.csproj            merge=union
# *.props             merge=union
